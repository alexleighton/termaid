; Invariant suite: faithful port of the upstream structural assertions
; (node/edge counts, exact labels, substring presence in the art, widths,
; alignment properties). Attached to the default `runtest` alias.
(test
 (name test_invariants)
 (modules test_invariants)
 (libraries termaid alcotest))

; Golden suite: exact box art compared against fixtures captured from the Rust
; oracle (test/golden/*.expected, regenerated by scripts/gen_golden.sh). The
; fixtures are checked in, so this needs no Rust toolchain at test time and runs
; under the default `runtest` alias.
(executable
 (name test_golden)
 (modules test_golden)
 (libraries termaid alcotest))

(rule
 (alias runtest)
 (deps
  test_golden.exe
  (glob_files_rec golden/*))
 (action
  (run %{dep:test_golden.exe} --compact)))
